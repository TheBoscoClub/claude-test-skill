{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Example install manifest for Phase P production validation",

  "name": "my-app",
  "version": "1.0.0",
  "description": "Example application for install manifest schema",
  "install_type": "user",

  "binaries": [
    {
      "name": "my-app-cli",
      "paths": [
        "~/.local/bin/my-app-cli",
        "/usr/local/bin/my-app-cli"
      ],
      "version_flag": "--version",
      "health_check": "my-app-cli --health"
    },
    {
      "name": "my-app-worker",
      "paths": ["~/.local/bin/my-app-worker"],
      "version_flag": "-V"
    }
  ],

  "services": [
    {
      "name": "my-app-api.service",
      "type": "user",
      "expected_state": "active",
      "health_endpoint": "http://localhost:8080/health"
    },
    {
      "name": "my-app-worker.service",
      "type": "user",
      "expected_state": "active"
    },
    {
      "name": "my-app-scheduler.timer",
      "type": "user",
      "expected_state": "active"
    }
  ],

  "config_files": [
    {
      "path": "~/.config/my-app/config.env",
      "required": true,
      "validate_command": "bash -n ~/.config/my-app/config.env"
    },
    {
      "path": "~/.config/my-app/settings.json",
      "required": false
    }
  ],

  "data_directories": [
    {
      "path": "~/.local/share/my-app",
      "required": true,
      "min_permissions": "700"
    },
    {
      "path": "~/.local/share/my-app/cache",
      "required": false,
      "min_permissions": "700"
    }
  ],

  "environment": {
    "required_vars": ["MY_APP_HOME", "MY_APP_DATA_DIR"],
    "optional_vars": ["MY_APP_DEBUG", "MY_APP_LOG_LEVEL"]
  },

  "ports": [
    {
      "port": 8080,
      "protocol": "tcp",
      "service": "my-app-api.service",
      "description": "REST API"
    },
    {
      "port": 8081,
      "protocol": "tcp",
      "service": "my-app-api.service",
      "description": "WebSocket for live updates"
    }
  ],

  "health_checks": [
    {
      "name": "API responding",
      "command": "curl -sf http://localhost:8080/health",
      "timeout": 5
    },
    {
      "name": "Database accessible",
      "command": "my-app-cli db ping",
      "timeout": 10
    },
    {
      "name": "Data directory readable",
      "command": "my-app-cli data check",
      "timeout": 30
    }
  ]
}
